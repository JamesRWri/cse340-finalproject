<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <main>
    <h1>Login to Your Account</h1>

    <% if (messages && messages.notice) { %>
      <div class="notice-message"><%= messages.notice %></div>
    <% } %>

    <div class="form-container">
      <form action="/account/login" method="POST" class="account-form">
        
        <label for="account_email">Email Address:</label>
        <input type="email" id="account_email" name="account_email" required placeholder="Enter your email" value="<%= locals.account_email || '' %>">

        <label for="account_password">Password:</label>
        <input type="password" id="account_password" name="account_password" required placeholder="Enter your password">

        <button type="submit">Log In</button>
      </form>

      <p class="form-switch">
        Don't have an account? <a href="/account/register">Sign up here</a>.
      </p>
    </div>
  </main>

</body>
</html>