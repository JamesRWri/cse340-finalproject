<main class="login-wrapper" style="max-width: 450px; margin: 3rem auto; padding: 2rem; font-family: Arial, sans-serif; border: 1px solid #e2e8f0; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); background: #fff;">
    
    <h1 style="margin-top: 0; margin-bottom: 1.5rem; font-size: 2rem; color: #2d3748;"><%= title %></h1>

    <% if (messages && messages.notice) { %>
        <div class="notice-message" style="background: #fed7d7; color: #9b2c2c; padding: 0.75rem; border-radius: 4px; margin-bottom: 1.5rem; font-weight: bold;">
            <%= messages.notice %>
        </div>
    <% } %>

    <form action="/account/login" method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label for="account_email" style="font-weight: bold; color: #4a5568;">Email Address:</label>
            <input type="email" id="account_email" name="account_email" required value="<%= locals.account_email || '' %>" placeholder="example@cse340.edu" style="padding: 0.75rem; border: 1px solid #cbd5e0; border-radius: 4px; font-size: 1rem;">
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label for="account_password" style="font-weight: bold; color: #4a5568;">Password:</label>
            <input type="password" id="account_password" name="account_password" required placeholder="Enter your password" style="padding: 0.75rem; border: 1px solid #cbd5e0; border-radius: 4px; font-size: 1rem;">
            <span style="font-size: 0.85rem; color: #718096;">Passwords must be at least 12 characters and contain a number, capital letter, and special character.</span>
        </div>

        <button type="submit" style="background: #3498db; color: white; padding: 0.75rem; border: none; border-radius: 4px; font-size: 1rem; font-weight: bold; cursor: pointer; margin-top: 0.5rem;">Sign In</button>
    </form>

    <hr style="border: 0; border-top: 1px solid #e2e8f0; margin: 2rem 0;">

    <p style="text-align: center; margin: 0; color: #4a5568;">
        No account? <a href="/account/register" style="color: #3498db; text-decoration: none; font-weight: bold;">Sign up here</a>
    </p>
</main>