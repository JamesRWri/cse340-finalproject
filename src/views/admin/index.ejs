<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <main>
    <h1>Administrative Management</h1>
    
    <% if (messages && messages.notice) { %>
      <div class="notice-message"><%= messages.notice %></div>
    <% } %>

    <div class="form-container" style="max-width: 600px; margin: 2rem auto;">
      <h2>Welcome to the Admin Portal</h2>
      <p>Select a management utility below to update the system:</p>
      
      <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem;">
        <li>
          <a href="/admin/vehicles" class="btn-details" style="text-decoration: none;">🚗 Manage Vehicle Inventory</a>
        </li>
        <li>
          <a href="/category" class="btn-details" style="background-color: var(--accent-color); text-decoration: none;">📁 Manage Categories</a>
        </li>
      </ul>
    </div>
  </main>
</body>
</html>