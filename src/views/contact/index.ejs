<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <main>
    <h1>Contact Our Team</h1>
    <p>Have a question about a vehicle listing or want to schedule a test drive? Drop us a message below.</p>

    <% if (messages && messages.notice) { %>
      <div class="notice-message"><%= messages.notice %></div>
    <% } %>

    <div class="form-container">
      <form action="/contact" method="POST" class="account-form">
        <label for="contact_name">Full Name:</label>
        <input type="text" id="contact_name" name="contact_name" required placeholder="John Doe" value="<%= locals.contact_name || '' %>">

        <label for="contact_email">Email Address:</label>
        <input type="email" id="contact_email" name="contact_email" required placeholder="you@example.com" value="<%= locals.contact_email || '' %>">

        <label for="contact_message">Your Message:</label>
        <textarea id="contact_message" name="contact_message" required placeholder="Write your inquiry here..." style="padding: 0.75rem; margin-bottom: 1.5rem; border-radius: var(--border-radius); border: 1px solid #ccc; font-family: inherit; min-height: 120px;"><%= locals.contact_message || '' %></textarea>

        <button type="submit">Send Message</button>
      </form>
    </div>
  </main>
</body>
</html>