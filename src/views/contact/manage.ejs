<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <main>
    <h1>Client Inquiries Management</h1>
    <p><a href="/admin" style="font-weight: bold;">← Return to Admin Panel</a></p>

    <% if (messages && messages.notice) { %>
      <div class="notice-message"><%= messages.notice %></div>
    <% } %>

    <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-top: 2rem;">
      <% if (messages && messages.length > 0) { %>
        <% messages.forEach(msg => { %>
          <div class="form-container" style="max-width: 100%; margin: 0; padding: 1.5rem; text-align: left;">
            <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #e1e4e6; padding-bottom: 0.5rem; margin-bottom: 1rem;">
              <strong style="color: var(--primary-color); font-size: 1.1rem;"><%= msg.contact_name %></strong>
              <span style="color: var(--text-light); font-size: 0.9rem;"><%= new Date(msg.contact_date).toLocaleString() %></span>
            </div>
            <p style="margin: 0 0 0.5rem 0;"><strong>Email:</strong> <a href="mailto:<%= msg.contact_email %>"><%= msg.contact_email %></a></p>
            <p style="margin: 0; background: var(--bg-color); padding: 1rem; border-radius: var(--border-radius); color: #444; font-style: italic;">
              "<%= msg.contact_message %>"
            </p>
          </div>
        <% }) %>
      <% } else { %>
        <div class="form-container" style="max-width: 100%; text-align: center;">
          <p>No client inquiries found in the database.</p>
        </div>
      <% } %>
    </div>
  </main>
</body>
</html>