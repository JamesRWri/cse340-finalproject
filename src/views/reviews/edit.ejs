<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css"> </head>
<body>

  <main>
    <h1><%= pageTitle || "Modify Your Review" %></h1>

    <% if (messages && messages.notice) { %>
      <div class="notice-message"><%= messages.notice %></div>
    <% } %>

    <div class="edit-review-container">
      <form action="/review/update" method="POST" class="edit-review-form">
        
        <label for="review_text">Update your comments:</label>
        <textarea id="review_text" name="review_text" rows="6" required><%= review.review_text %></textarea>

        <input type="hidden" name="review_id" value="<%= review.review_id %>">
        <input type="hidden" name="inv_id" value="<%= review.inv_id %>">

        <div class="form-actions">
          <button type="submit" class="btn-save">Save Changes</button>
          <a href="/vehicles/detail/<%= review.inv_id %>" class="btn-cancel">Cancel</a>
        </div>
      </form>
    </div>
  </main>

</body>
</html>