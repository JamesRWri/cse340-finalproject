<main class="form-container">
    <h1><%= title %></h1>

    <% if (locals.messages && locals.messages.notice) { %>
        <div class="alert-message"><%= messages.notice %></div>
    <% } %>

    <form action="/reviews/update" method="post" class="management-form">
        <input type="hidden" name="review_id" value="<%= review.review_id %>">

        <label for="review_text"><strong>Edit your review:</strong></label>
        <textarea id="review_text" name="review_text" required rows="5"><%= review.review_text %></textarea>

        <button type="submit" class="btn-submit">Update Review</button>
        <a href="/account/dashboard" class="btn-cancel" style="display: block; text-align: center; margin-top: 1rem; color: #666;">Cancel</a>
    </form>
</main>