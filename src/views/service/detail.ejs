<main class="form-container">
    <h1><%= title %></h1>

    <% if (locals.messages && locals.messages.notice) { %>
        <div class="alert-message"><%= messages.notice %></div>
    <% } %>

    <form action="/service/book" method="post" class="management-form">
        <p>All fields are required.</p>

        <label for="service_vehicle_info">Vehicle Details (Year, Make, Model):</label>
        <input 
            type="text" 
            id="service_vehicle_info" 
            name="service_vehicle_info" 
            required 
            placeholder="e.g., 2018 Toyota Camry">

        <label for="service_description">Problem Description / Services Needed:</label>
        <textarea 
            id="service_description" 
            name="service_description" 
            required 
            placeholder="Please describe what your vehicle needs (e.g., oil change, brake squeak, engine diagnostics)..."></textarea>

        <button type="submit" class="btn-submit">Submit Request</button>
    </form>
</main>