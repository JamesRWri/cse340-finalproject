<main class="management-container">
    <h1><%= title %></h1>
    <a href="/vehicles/inventory" style="background-color: #333; color: white; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px; font-size: 0.9rem;">
            🚘 Back to Car Lot
        </a>
    <a href="/service/detail" style="display: inline-block; margin-left: 3rem; background-color: #28a745; color: white; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px; font-weight: bold; font-size: 0.9rem;">
        ➕ Request Another Service
    </a>

    <% if (locals.messages && locals.messages.notice) { %>
        <div class="alert-message"><%= messages.notice %></div>
    <% } %>

    <% if (history && history.length === 0) { %>
        <p>You haven't submitted any service requests yet.</p>
    <% } else { %>
        <div class="service-list">
            <% history.forEach(item => { %>
                <div class="service-card" style="border: 1px solid #ccc; padding: 1.25rem; margin-bottom: 1.25rem; border-radius: 6px; background-color: #fbfbfb;">
                    <h3><%= item.service_vehicle_info %></h3>
                    <p><strong>Status:</strong> <span class="status-badge" style="background: #e2e8f0; padding: 0.25rem 0.5rem; border-radius: 4px; font-weight: bold;"><%= item.service_status %></span></p>
                    <p><strong>Submitted on:</strong> <%= new Date(item.service_date).toLocaleDateString() %></p>
                    <p><strong>Description:</strong> <%= item.service_description %></p>
                </div>
            <% }) %>
        </div>
    <% } %>
</main>