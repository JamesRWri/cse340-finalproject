<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .filter-container {
      margin-bottom: 2.5rem;
      text-align: center;
    }
    .classification-toggle-group {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 15px;
    }
    .toggle-btn {
      padding: 10px 20px;
      border: 2px solid #0056b3;
      background-color: transparent;
      color: #0056b3;
      font-weight: bold;
      border-radius: 25px;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    .toggle-btn:hover, .toggle-btn.active {
      background-color: #0056b3;
      color: #ffffff;
    }
  </style>
</head>
<body>

  <main class="inventory-wrapper" style="max-width: 1200px; margin: 0 auto; padding: 2rem;">
    <h1 style="margin-bottom: 2rem; border-bottom: 2px solid #333; padding-bottom: 0.5rem;"><%= title %></h1>

    <% if (locals.classifications && classifications.length > 0) { %>
      <div class="filter-container">
        <h3>Filter by Classification</h3>
        <div class="classification-toggle-group">
          <button class="toggle-btn active" data-id="all">All Vehicles</button>
          
          <% 
            // Quick EJS helper to filter out duplicates by name
            const uniqueClassifications = [];
            const seenNames = new Set();
            classifications.forEach(c => {
              const name = c.classification_name.trim().toLowerCase();
              if (!seenNames.has(name)) {
                seenNames.add(name);
                uniqueClassifications.push(c);
              }
            });
          %>

          <% uniqueClassifications.forEach(classification => { %>
            <button class="toggle-btn" data-id="<%= classification.classification_id %>">
              <%= classification.classification_name.trim() %>
            </button>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (vehicles && vehicles.length > 0) { %>
        <div class="inventory-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
            <% vehicles.forEach(vehicle => { %>
                <div class="vehicle-card" 
                     data-id="<%= vehicle.classification_id %>"
                     style="border: 1px solid #ddd; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05); background: #fff;">
                    <img src="<%= vehicle.inv_thumbnail %>" alt="<%= vehicle.inv_make %> <%= vehicle.inv_model %>" style="width: 100%; height: 200px; object-fit: cover; background: #eee;">
                    <div style="padding: 1.5rem;">
                        <h2 style="margin: 0 0 0.5rem 0; font-size: 1.5rem;"><%= vehicle.inv_make %> <%= vehicle.inv_model %></h2>
                        <p style="color: #666; margin: 0 0 1rem 0;">Year: <%= vehicle.inv_year %> | <%= vehicle.inv_miles ? vehicle.inv_miles.toLocaleString() : 0 %> miles</p>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-size: 1.25rem; font-weight: bold; color: #2ecc71;">$<%= Number(vehicle.inv_price).toLocaleString() %></span>
                            <a href="/vehicles/detail/<%= vehicle.inv_id %>" style="background: #3498db; color: #fff; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px; font-weight: bold;">View Details</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div style="padding: 3rem; text-align: center; background: #f9f9f9; border: 2px dashed #ccc; border-radius: 8px;">
            <h2>Our showroom lot is currently empty!</h2>
            <p>No vehicles found matching the system registry.</p>
        </div>
    <% } %>

    <div class="navigation-actions" style="margin-bottom: 1.5rem;">
      <a href="/service/detail" class="btn-action" style="display: inline-block; margin-top: 3rem; background-color: #0056b3; color: white; padding: 0.75rem 1.5rem; text-decoration: none; border-radius: 4px; font-weight: bold;">
          🛠️ Book a Service Appointment
      </a>
    </div>
  </main>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const toggleButtons = document.querySelectorAll(".toggle-btn");
      const vehicleCards = document.querySelectorAll(".vehicle-card");

      toggleButtons.forEach(button => {
        button.addEventListener("click", () => {
          toggleButtons.forEach(btn => btn.classList.remove("active"));
          button.classList.add("active");

          const targetId = button.getAttribute("data-id");

          vehicleCards.forEach(card => {
            const cardId = card.getAttribute("data-id");
            
            if (targetId === "all" || cardId === targetId) {
              card.style.display = "block";
            } else {
              card.style.display = "none";
            }
          });
        });
      });
    });
  </script>
</body>
</html>