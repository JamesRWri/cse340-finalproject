<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <main class="inventory-wrapper" style="max-width: 1200px; margin: 0 auto; padding: 2rem;">
    <h1 style="margin-bottom: 2rem; border-bottom: 2px solid #333; padding-bottom: 0.5rem;"><%= title %></h1>

    <% if (vehicles && vehicles.length > 0) { %>
        <div class="inventory-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
            <% vehicles.forEach(vehicle => { %>
                <div class="vehicle-card" style="border: 1px solid #ddd; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05); background: #fff;">
                    <img src="<%= vehicle.inv_thumbnail %>" alt="<%= vehicle.inv_make %> <%= vehicle.inv_model %>" style="width: 100%; height: 200px; object-fit: cover; background: #eee;">
                    <div style="padding: 1.5rem;">
                        <h2 style="margin: 0 0 0.5rem 0; font-size: 1.5rem;"><%= vehicle.inv_make %> <%= vehicle.inv_model %></h2>
                        <p style="color: #666; margin: 0 0 1rem 0;">Year: <%= vehicle.inv_year %> | <%= vehicle.inv_miles.toLocaleString() %> miles</p>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-size: 1.25rem; font-weight: bold; color: #2ecc71;">$<%= Number(vehicle.inv_price).toLocaleString() %></span>
                            <a href="/vehicles/detail/<%= vehicle.inv_id %>" style="background: #3498db; color: #fff; padding: 0.5rem 1rem; text-decoration: none; border-radius: 4px; font-weight: bold;">View Details</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div style="padding: 3rem; text-align: center; background: #f9f9f9; border: 2px dashed #ccc; border-radius: 8px;">
            <h2>Our showroom lot is currently empty!</h2>
            <p>No vehicles found matching the system registry.</p>
        </div>
    <% } %>
</main>

</body>
</html>