<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <style>
        body { font-family: sans-serif; background-color: #fafafa; padding: 2rem; color: #000; }
        header { border-bottom: 3px solid #000; padding-bottom: 1rem; margin-bottom: 2rem; }
        .vehicle-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
        .vehicle-card { background: #fff; border: 3px solid #000; box-shadow: 5px 5px 0px #000; padding: 1.25rem; display: flex; flex-direction: column; }
        .vehicle-title { font-size: 1.25rem; font-weight: bold; margin: 0 0 0.5rem 0; }
        .vehicle-title a { color: #000; text-decoration: underline; }
        .vehicle-title a:hover { color: #0055cc; }
        .vehicle-price { font-size: 1.5rem; color: #081437; font-weight: bold; margin: 0.5rem 0; }
        .tag { display: inline-block; padding: 0.25rem 0.5rem; border: 1px solid #000; font-size: 0.8rem; font-weight: bold; background: #eee; margin-right: 0.5rem; }
        .status-badge { background: #e0f2fe; color: #0369a1; padding: 0.1rem 0.3rem; }
    </style>
</head>
<body>
    <header>
        <h1>Dealership Management System</h1>
        <p>Active Model View Controller Architecture Preview Sandbox</p>
    </header>

    <main>
        <h2>Current Lot Inventory</h2>
        <div class="vehicle-grid">
            <% vehicleList.forEach(function(car) { %>
                <div class="vehicle-card">
                    <div class="vehicle-title">
                        <a href="/vehicles/detail/<%= car.inv_id %>">
                            <%= car.inv_year %> <%= car.inv_make %> <%= car.inv_model %>
                        </a>
                    </div>
                    <div>
                        <span class="tag"><%= car.category || 'Vehicle' %></span>
                        <span class="tag"><%= (car.inv_miles || car.mileage || 0).toLocaleString() %> miles</span>
                    </div>
                    <div class="vehicle-price">$<%= (car.inv_price || car.price || 0).toLocaleString() %></div>
                    <div style="margin-top: auto; font-size: 0.85rem;">
                        Status: <strong class="status-badge"><%= car.status || 'Available' %></strong>
                    </div>
                </div>
            <% }); %>
        </div>
    </main>
</body>
</html>